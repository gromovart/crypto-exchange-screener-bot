# ============================================
# CRYPTO EXCHANGE SCREENER BOT
# Конфигурация: Разработка (dev)
# ============================================
#
# Использование:
#   cp .env.example .env
#   nano .env
#
# Все переменные соответствуют полям в config.go
# ============================================

ENVIRONMENT=dev

# ============================================
# 1. БИРЖА И API КЛЮЧИ
# ============================================

# Основная биржа: bybit, binance
EXCHANGE=bybit

# Тип торговли: futures, spot
EXCHANGE_TYPE=futures

# Категория фьючерсов (только Bybit): linear, inverse
FUTURES_CATEGORY=linear

# Универсальный формат API (приоритет над BYBIT_* если заполнены)
API_KEY=
API_SECRET=
BASE_URL=

# ---- Bybit ----
# Получить: https://www.bybit.com/app/user/api-management
# Права: Read-only достаточно для мониторинга
BYBIT_API_KEY=
BYBIT_SECRET_KEY=
BYBIT_API_URL=https://api.bybit.com

# ---- Binance (если используется) ----
# Получить: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ============================================
# 2. СИМВОЛЫ И ФИЛЬТРАЦИЯ
# ============================================

# Фильтр символов: all / список через запятую (BTC,ETH,SOL)
SYMBOL_FILTER=all

# Исключить символы с паттернами (левериджи, токены 3x)
EXCLUDE_SYMBOLS=*DOWN*,*UP*,*BEAR*,*BULL*,*3L*,*3S*,*5L*,*5S*

# Максимум символов для мониторинга (больше = выше нагрузка)
MAX_SYMBOLS_TO_MONITOR=100

# Минимальный суточный объём в USDT (отсев малоликвидных пар)
MIN_VOLUME_FILTER=100000

# Интервал обновления данных в секундах
UPDATE_INTERVAL=10

# ============================================
# 3. ДВИЖОК АНАЛИЗА
# ============================================

# Интервал между циклами анализа (секунды)
ANALYSIS_UPDATE_INTERVAL=15

# Периоды анализа в минутах (через запятую)
ANALYSIS_PERIODS=1,5,15,30

# Максимум символов за один цикл анализа
ANALYSIS_MAX_SYMBOLS_PER_RUN=50

# Общий порог сигнала в процентах
ANALYSIS_SIGNAL_THRESHOLD=0.5

# Хранить исторические данные (часы)
ANALYSIS_RETENTION_PERIOD=24

# Кэширование результатов анализа
ANALYSIS_ENABLE_CACHE=true

# Параллельная обработка символов
ANALYSIS_ENABLE_PARALLEL=true

# Количество потоков для параллельной обработки
ANALYSIS_MAX_WORKERS=5

# Минимальное количество точек данных для анализа
ANALYSIS_MIN_DATA_POINTS=3

# ============================================
# 4. АНАЛИЗАТОРЫ ТРЕНДОВ
# ============================================

# ---- Анализатор роста ----
GROWTH_ANALYZER_ENABLED=true
GROWTH_ANALYZER_MIN_CONFIDENCE=60.0
GROWTH_ANALYZER_MIN_GROWTH=2.0
GROWTH_ANALYZER_CONTINUITY_THRESHOLD=0.7

# ---- Анализатор падения ----
FALL_ANALYZER_ENABLED=true
FALL_ANALYZER_MIN_CONFIDENCE=60.0
FALL_ANALYZER_MIN_FALL=2.0
FALL_ANALYZER_CONTINUITY_THRESHOLD=0.7

# ---- Анализатор непрерывности тренда ----
CONTINUOUS_ANALYZER_ENABLED=true
CONTINUOUS_ANALYZER_MIN_POINTS=3

# ---- Анализатор объёма ----
VOLUME_ANALYZER_ENABLED=true
VOLUME_ANALYZER_MIN_CONFIDENCE=30.0
VOLUME_ANALYZER_MIN_VOLUME=100000.0

# ---- Анализатор открытого интереса (OI) ----
# Только для фьючерсов
OPEN_INTEREST_ANALYZER_ENABLED=false
OPEN_INTEREST_MIN_CONFIDENCE=50.0
OPEN_INTEREST_MIN_PRICE_CHANGE=1.0
OPEN_INTEREST_MIN_PRICE_FALL=1.0
OPEN_INTEREST_MIN_OI_CHANGE=5.0
OPEN_INTEREST_EXTREME_THRESHOLD=1.5
OPEN_INTEREST_ANALYZER_WEIGHT=0.6
OPEN_INTEREST_NOTIFY_ENABLED=true

# ============================================
# 5. СЧЁТЧИК СИГНАЛОВ (COUNTER ANALYZER)
# ============================================

COUNTER_ANALYZER_ENABLED=true

# Базовый период в минутах (рост/падение за N минут = 1 сигнал)
COUNTER_BASE_PERIOD_MINUTES=1

# Период окна анализа: 5m, 15m, 30m, 1h, 4h, 1d
COUNTER_ANALYSIS_PERIOD=15m

# Пороги для отправки уведомлений пользователям (%)
# Также используются как дефолтные пороги для новых пользователей
COUNTER_GROWTH_THRESHOLD=2.0
COUNTER_FALL_THRESHOLD=2.0

# Отслеживать направления
COUNTER_TRACK_GROWTH=true
COUNTER_TRACK_FALL=true

# Уведомлять при каждом сигнале
COUNTER_NOTIFY_ON_SIGNAL=true

# Уведомлять каждые N сигналов (1 = каждый)
COUNTER_NOTIFICATION_THRESHOLD=1

# Провайдер графиков: coinglass, tradingview
COUNTER_CHART_PROVIDER=coinglass

# Включить уведомления от счётчика
COUNTER_NOTIFICATION_ENABLED=true

# Лимиты сигналов (rate limiting) для разных периодов
COUNTER_MAX_SIGNALS_5MIN=5
COUNTER_MAX_SIGNALS_15MIN=8
COUNTER_MAX_SIGNALS_30MIN=10
COUNTER_MAX_SIGNALS_1HOUR=12
COUNTER_MAX_SIGNALS_4HOURS=15
COUNTER_MAX_SIGNALS_1DAY=20

# ============================================
# 6. ФИЛЬТРЫ СИГНАЛОВ
# ============================================

SIGNAL_FILTERS_ENABLED=true

# Глобальная минимальная уверенность для всех сигналов (%)
MIN_CONFIDENCE=50.0

# Максимум сигналов в минуту на символ
MAX_SIGNALS_PER_MIN=5

# Паттерны символов для включения (* = все)
SIGNAL_INCLUDE_PATTERNS=

# Паттерны символов для исключения
SIGNAL_EXCLUDE_PATTERNS=

# ============================================
# 7. TELEGRAM
# ============================================

# Включить Telegram бота
TELEGRAM_ENABLED=false

# Токен бота (получить у @BotFather)
TG_API_KEY=

# Username бота без @ (для deeplink'ов)
TG_BOT_USERNAME=

# Chat ID для системных уведомлений (получить у @userinfobot)
TG_CHAT_ID=

# Что уведомлять
TELEGRAM_NOTIFY_GROWTH=true
TELEGRAM_NOTIFY_FALL=true

# Пороги для системных уведомлений (%)
TELEGRAM_GROWTH_THRESHOLD=2.0
TELEGRAM_FALL_THRESHOLD=2.0

# Формат сообщений: compact, detailed
MESSAGE_FORMAT=detailed

# Включить статистику 24ч в уведомлениях
INCLUDE_24H_STATS=true

# ---- Режим работы бота ----
# polling — для разработки (не нужен публичный IP)
# webhook — для продакшена (нужен публичный домен)
TELEGRAM_MODE=polling

# ---- Polling настройки (активны при TELEGRAM_MODE=polling) ----
POLLING_TIMEOUT=30
POLLING_LIMIT=100
POLLING_RETRY_INTERVAL=5

# ---- Webhook настройки (активны при TELEGRAM_MODE=webhook) ----
WEBHOOK_DOMAIN=localhost
WEBHOOK_PORT=8443
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET_TOKEN=your_secret_token_here
WEBHOOK_MAX_BODY_SIZE=1048576
WEBHOOK_USE_TLS=false
WEBHOOK_TLS_CERT_PATH=
WEBHOOK_TLS_KEY_PATH=

# ---- Telegram Stars (опционально, для оплаты) ----
TELEGRAM_STARS_PROVIDER_TOKEN=
TELEGRAM_STARS_BOT_USERNAME=

# ============================================
# 8. MAX МЕССЕНДЖЕР
# ============================================

# Включить MAX бота
MAX_ENABLED=false

# Токен MAX бота (получить у @metabot в MAX)
MAX_BOT_TOKEN=

# Chat ID для широковещательных сигналов (опционально)
MAX_CHAT_ID=

# Режим работы: polling (dev) / webhook (prod)
MAX_MODE=polling

# ---- MAX Webhook настройки (только при MAX_MODE=webhook) ----
MAX_WEBHOOK_DOMAIN=yourdomain.com
MAX_WEBHOOK_PORT=8444
MAX_WEBHOOK_PATH=/max/webhook
MAX_WEBHOOK_SECRET_TOKEN=
MAX_WEBHOOK_MAX_BODY_SIZE=1048576
MAX_WEBHOOK_USE_TLS=false
MAX_WEBHOOK_TLS_CERT_PATH=
MAX_WEBHOOK_TLS_KEY_PATH=

# ============================================
# 9. МОНИТОРИНГ
# ============================================

# Chat ID для технического мониторинга (группа/канал)
MONITORING_CHAT_ID=

# Включить мониторинг
MONITORING_ENABLED=false

# Что уведомлять
MONITORING_NOTIFY_GROWTH=true
MONITORING_NOTIFY_FALL=true

# Тестовый режим (не отправлять реальные уведомления)
MONITORING_TEST_MODE=false

# ============================================
# 10. НАСТРОЙКИ ОТОБРАЖЕНИЯ В КОНСОЛИ
# ============================================

# Режим вывода: compact, detailed
DISPLAY_MODE=compact

# Максимум сигналов за один вывод
MAX_SIGNALS_PER_BATCH=10

# Минимальная уверенность для вывода в консоль (%)
MIN_CONFIDENCE_DISPLAY=30

DISPLAY_GROWTH=true
DISPLAY_FALL=true

# Какие периоды выводить (минуты)
DISPLAY_PERIODS=5,15,30

# Цветной вывод в терминале
USE_COLORS=true

# ============================================
# 11. ШИНА СОБЫТИЙ (EVENT BUS)
# ============================================

# Размер буфера очереди событий
EVENT_BUS_BUFFER_SIZE=1000

# Количество воркеров-обработчиков
EVENT_BUS_WORKER_COUNT=5

# Собирать метрики шины
EVENT_BUS_ENABLE_METRICS=true

# Логировать все события (только для отладки)
EVENT_BUS_ENABLE_LOGGING=false

# ============================================
# 12. ПОДПИСКИ И БИЛЛИНГ (опционально)
# ============================================

# Включить систему подписок
ENABLE_SUBSCRIPTIONS=false

# Stripe (для платёжной системы)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Пробный период для новых пользователей (дни)
DEFAULT_TRIAL_DAYS=7

# Автопродление подписок
ENABLE_AUTO_RENEWAL=true

# ============================================
# 13. ЛОГИРОВАНИЕ
# ============================================

# Уровень: debug, info, warn, error
LOG_LEVEL=info

# Путь к файлу логов
LOG_FILE=logs/app.log

# Выводить логи в консоль
LOG_TO_CONSOLE=true

# Записывать логи в файл
LOG_TO_FILE=true

# Режим отладки (подробные логи)
DEBUG_MODE=false

# HTTP сервер для health-check и метрик
HTTP_ENABLED=false
HTTP_PORT=8080

# ============================================
# 14. ПРОИЗВОДИТЕЛЬНОСТЬ
# ============================================

# Максимум параллельных HTTP запросов к бирже
MAX_CONCURRENT_REQUESTS=10

# Задержка между запросами к API (для rate limit)
RATE_LIMIT_DELAY=100ms

# ============================================
# 15. БАЗА ДАННЫХ (POSTGRESQL)
# ============================================

DB_HOST=localhost
DB_PORT=5432
DB_USER=bot
DB_PASSWORD=bot123
DB_NAME=cryptobot
DB_SSLMODE=disable

# Включить БД (false = приложение работает без DB)
DB_ENABLED=true

# Настройки пула соединений
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=10m

# Миграции
DB_MIGRATIONS_PATH=./internal/infrastructure/persistence/postgres/migrations
DB_ENABLE_AUTO_MIGRATE=true

# ============================================
# 16. REDIS
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Включить Redis (false = кэширование отключено)
REDIS_ENABLED=true

# Настройки пула
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5
REDIS_MAX_RETRIES=3
REDIS_MIN_RETRY_BACKOFF=8ms
REDIS_MAX_RETRY_BACKOFF=512ms

# Таймауты
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_TIMEOUT=4s
REDIS_IDLE_TIMEOUT=5m

# Прочее
REDIS_MAX_CONN_AGE=0
REDIS_DEFAULT_TTL=1h
REDIS_USE_TLS=false

# ============================================
# 17. НАСТРОЙКИ ПОЛЬЗОВАТЕЛЕЙ ПО УМОЛЧАНИЮ
# ============================================

# Язык интерфейса для новых пользователей
DEFAULT_LANGUAGE=ru

# Часовой пояс по умолчанию
DEFAULT_TIMEZONE=Europe/Moscow



# ============================================
# 18. Т-БАНК ЭКВАЙРИНГ (СБП / карта)
# ============================================

TBANK_ENABLED=false
TBANK_TERMINAL_KEY=<TerminalKey из Т-Бизнес>
TBANK_PASSWORD=<пароль терминала>

# URL для уведомлений от Т-Банк (должен быть публично доступен)
TBANK_NOTIFY_URL=https://yourdomain.com/notify
TBANK_NOTIFY_PORT=8082

# URL редиректа после оплаты — Telegram бот
TBANK_SUCCESS_URL=https://t.me/your_telegram_bot
TBANK_FAIL_URL=https://t.me/your_telegram_bot

# URL редиректа после оплаты — MAX бот
MAX_TBANK_SUCCESS_URL=https://max.ru/your_max_bot
MAX_TBANK_FAIL_URL=https://max.ru/your_max_bot


# ============================================
# 19. AUTH OTP SERVER (для внешних сервисов)
# ============================================
# Внутренний HTTP-сервер для авторизации через MAX OTP.
# Слушает только на 127.0.0.1 — не доступен снаружи.

AUTH_ENABLED=false
AUTH_PORT=8081

# Секрет для заголовка X-Internal-Secret (сгенерируйте: openssl rand -hex 32)
AUTH_INTERNAL_SECRET=

# TTL одноразового кода в секундах (default: 300 = 5 минут)
AUTH_OTP_TTL_SEC=300


# ============================================
# КОНЕЦ КОНФИГУРАЦИИ
# ============================================
#
# Команды для запуска:
#   make run          — запуск из исходников (dev)
#   make build        — сборка бинарника
#   make run-prod     — запуск продакшен бинарника
